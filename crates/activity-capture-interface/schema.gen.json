{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActivityCaptureInterfaceSchema",
  "type": "object",
  "properties": {
    "app_identity": {
      "$ref": "#/$defs/AppIdentity"
    },
    "browser_context": {
      "$ref": "#/$defs/BrowserContext"
    },
    "capabilities": {
      "$ref": "#/$defs/Capabilities"
    },
    "capture_candidate": {
      "$ref": "#/$defs/CaptureCandidate"
    },
    "capture_decision": {
      "$ref": "#/$defs/CaptureDecision"
    },
    "capture_policy": {
      "$ref": "#/$defs/CapturePolicy"
    },
    "normalized_snapshot": {
      "$ref": "#/$defs/NormalizedSnapshot"
    },
    "normalized_snapshot_spec": {
      "$ref": "#/$defs/NormalizedSnapshotSpec"
    },
    "raw_capture_sample": {
      "$ref": "#/$defs/RawCaptureSample"
    },
    "sanitized_browser_url": {
      "$ref": "#/$defs/SanitizedBrowserUrl"
    }
  },
  "required": [
    "capture_policy",
    "app_identity",
    "browser_context",
    "sanitized_browser_url",
    "capture_candidate",
    "capture_decision",
    "normalized_snapshot_spec",
    "normalized_snapshot",
    "raw_capture_sample",
    "capabilities"
  ],
  "$defs": {
    "ActivityKind": {
      "type": "string",
      "enum": [
        "foreground_window",
        "browser",
        "audio_session"
      ]
    },
    "AppIdKind": {
      "type": "string",
      "enum": [
        "bundle_id",
        "executable_path",
        "process_name",
        "pid"
      ]
    },
    "AppIdentity": {
      "type": "object",
      "properties": {
        "app_id": {
          "type": "string"
        },
        "app_id_kind": {
          "$ref": "#/$defs/AppIdKind"
        },
        "app_name": {
          "type": "string"
        },
        "bundle_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "executable_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "pid": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "pid",
        "app_name",
        "app_id",
        "app_id_kind"
      ]
    },
    "BrowserContext": {
      "type": "object",
      "properties": {
        "is_private": {
          "type": "boolean"
        },
        "raw_url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "is_private"
      ]
    },
    "BrowserPolicy": {
      "type": "object",
      "properties": {
        "block_private_browsing": {
          "type": "boolean"
        },
        "require_url_for_text_access": {
          "type": "boolean"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DomainRule"
          }
        },
        "strip_fragment": {
          "type": "boolean"
        },
        "strip_query": {
          "type": "boolean"
        }
      },
      "required": [
        "rules",
        "require_url_for_text_access",
        "block_private_browsing",
        "strip_query",
        "strip_fragment"
      ]
    },
    "BundleRule": {
      "type": "object",
      "properties": {
        "access": {
          "$ref": "#/$defs/CaptureAccess"
        },
        "bundle_id": {
          "type": "string"
        }
      },
      "required": [
        "bundle_id",
        "access"
      ]
    },
    "Capabilities": {
      "type": "object",
      "properties": {
        "can_capture_browser_url": {
          "type": "boolean"
        },
        "can_capture_visible_text": {
          "type": "boolean"
        },
        "can_watch": {
          "type": "boolean"
        },
        "requires_accessibility_permission": {
          "type": "boolean"
        }
      },
      "required": [
        "can_watch",
        "can_capture_visible_text",
        "can_capture_browser_url",
        "requires_accessibility_permission"
      ]
    },
    "CaptureAccess": {
      "type": "string",
      "enum": [
        "none",
        "metadata",
        "url",
        "full"
      ]
    },
    "CaptureCandidate": {
      "type": "object",
      "properties": {
        "activity_kind": {
          "$ref": "#/$defs/ActivityKind"
        },
        "app": {
          "$ref": "#/$defs/AppIdentity"
        },
        "browser": {
          "anyOf": [
            {
              "$ref": "#/$defs/BrowserContext"
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "$ref": "#/$defs/SnapshotSource"
        }
      },
      "required": [
        "app",
        "activity_kind",
        "source"
      ]
    },
    "CaptureDecision": {
      "type": "object",
      "properties": {
        "access": {
          "$ref": "#/$defs/CaptureAccess"
        },
        "activity_kind": {
          "$ref": "#/$defs/ActivityKind"
        },
        "skip": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/SnapshotSource"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "access",
        "skip",
        "source",
        "activity_kind"
      ]
    },
    "CapturePolicy": {
      "type": "object",
      "properties": {
        "app_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BundleRule"
          }
        },
        "browser": {
          "$ref": "#/$defs/BrowserPolicy"
        },
        "mode": {
          "$ref": "#/$defs/PolicyMode"
        }
      },
      "required": [
        "mode",
        "app_rules",
        "browser"
      ]
    },
    "ContentLevel": {
      "type": "string",
      "enum": [
        "metadata",
        "url",
        "full"
      ]
    },
    "DomainRule": {
      "type": "object",
      "properties": {
        "access": {
          "$ref": "#/$defs/CaptureAccess"
        },
        "domain": {
          "type": "string"
        },
        "include_subdomains": {
          "type": "boolean"
        }
      },
      "required": [
        "domain",
        "include_subdomains",
        "access"
      ]
    },
    "NormalizedSnapshot": {
      "type": "object",
      "properties": {
        "activity_kind": {
          "$ref": "#/$defs/ActivityKind"
        },
        "app": {
          "$ref": "#/$defs/AppIdentity"
        },
        "app_name": {
          "type": "string"
        },
        "bundle_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "captured_at": {
          "$ref": "#/$defs/SystemTime"
        },
        "content_level": {
          "$ref": "#/$defs/ContentLevel"
        },
        "focused_window_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "pid": {
          "type": "integer",
          "format": "int32"
        },
        "source": {
          "$ref": "#/$defs/SnapshotSource"
        },
        "text_anchor_confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextAnchorConfidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "text_anchor_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "text_anchor_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextAnchorKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "text_anchor_prefix": {
          "type": [
            "string",
            "null"
          ]
        },
        "text_anchor_selected_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "text_anchor_suffix": {
          "type": [
            "string",
            "null"
          ]
        },
        "text_anchor_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "visible_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "window_title": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "app",
        "activity_kind",
        "captured_at",
        "pid",
        "app_name",
        "content_level",
        "source"
      ]
    },
    "NormalizedSnapshotSpec": {
      "type": "object",
      "properties": {
        "access": {
          "$ref": "#/$defs/CaptureAccess"
        },
        "activity_kind": {
          "$ref": "#/$defs/ActivityKind"
        },
        "app": {
          "$ref": "#/$defs/AppIdentity"
        },
        "captured_at": {
          "$ref": "#/$defs/SystemTime"
        },
        "focused_window_id": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "source": {
          "$ref": "#/$defs/SnapshotSource"
        },
        "text_anchor": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextAnchor"
            },
            {
              "type": "null"
            }
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "visible_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "window_title": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "captured_at",
        "app",
        "activity_kind",
        "access",
        "source"
      ]
    },
    "PolicyMode": {
      "type": "string",
      "enum": [
        "opt_in",
        "opt_out"
      ]
    },
    "RawCaptureSample": {
      "type": "object",
      "properties": {
        "captured_at": {
          "$ref": "#/$defs/SystemTime"
        },
        "snapshot": {
          "anyOf": [
            {
              "$ref": "#/$defs/NormalizedSnapshot"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "captured_at"
      ]
    },
    "SanitizedBrowserUrl": {
      "type": "object",
      "properties": {
        "host": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url"
      ]
    },
    "SnapshotSource": {
      "type": "string",
      "enum": [
        "accessibility",
        "workspace"
      ]
    },
    "SystemTime": {
      "type": "object",
      "properties": {
        "nanos_since_epoch": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "secs_since_epoch": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "secs_since_epoch",
        "nanos_since_epoch"
      ]
    },
    "TextAnchor": {
      "type": "object",
      "properties": {
        "confidence": {
          "$ref": "#/$defs/TextAnchorConfidence"
        },
        "identity": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/TextAnchorKind"
        },
        "prefix": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "suffix": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind",
        "identity",
        "confidence"
      ]
    },
    "TextAnchorConfidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "TextAnchorKind": {
      "type": "string",
      "enum": [
        "focused_edit",
        "selected_text",
        "focused_element",
        "document",
        "none"
      ]
    }
  }
}